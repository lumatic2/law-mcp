# 법제처 국가법령정보 공동활용 OpenAPI 인증값 — **필수**
#
# 발급: https://open.law.go.kr/LSO/openApi/cuAskList.do (메일주소 회원가입·로그인 후 신청)
# 확인: https://open.law.go.kr/LSO/usr/usrOcInfoMod.do (API인증키관리)
#
# 이 값이 없으면 노출 도구 11개 중 9개가 동작하지 않는다(용어 검증 2종만 로컬로 돈다).
LAW_API_OC=your_openapi_oc_value

# 구 변수명. LAW_API_OC 가 없을 때만 폴백으로 읽는다.
LAW_API_KEY=optional_fallback_value

# 상류 엔드포인트 — 보통 건드릴 일이 없다.
LAW_SEARCH_BASE_URL=https://www.law.go.kr/DRF/lawSearch.do
LAW_SERVICE_BASE_URL=https://www.law.go.kr/DRF/lawService.do
